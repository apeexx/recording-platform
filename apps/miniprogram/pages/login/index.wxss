.login-page{min-height:100vh;box-sizing:border-box;padding:112rpx 44rpx 64rpx;background:#f7f5f1;text-align:center}.brand-title{font-size:48rpx;font-weight:750;color:#29221d}.brand-mark{width:132rpx;height:132rpx;margin:28rpx auto 26rpx;border-radius:38rpx;overflow:hidden;box-shadow:0 16rpx 45rpx rgba(75,55,40,.1)}.brand-mark image{width:132rpx;height:132rpx}.brand-slogan{font-size:32rpx;font-weight:650;color:#493a30}.brand-copy{margin:14rpx 0 52rpx;color:#84776d;font-size:27rpx}.login-card{position:relative;text-align:left;background:#fff;border:1rpx solid #ebe5dd;border-radius:30rpx;padding:42rpx 34rpx 78rpx;box-shadow:0 24rpx 60rpx rgba(75,55,40,.08)}.mode-title{font-size:36rpx;font-weight:700}.mode-copy{color:#8b8178;font-size:25rpx;margin:12rpx 0 28rpx}.login-input{height:88rpx;box-sizing:border-box;width:100%;padding:0 28rpx;border:1rpx solid #ded6ce;border-radius:18rpx;background:#fcfbf9;font-size:28rpx}.login-input+.login-input{margin-top:20rpx}.wechat-button,.account-button{height:96rpx;border-radius:20rpx;color:#fff;font-weight:650;display:flex;align-items:center;justify-content:center}.wechat-button{background:#07c160}.wechat-button image{width:44rpx;height:44rpx;margin-right:18rpx}.account-button{background:#765442;margin-top:28rpx}.switch{position:absolute;right:34rpx;bottom:28rpx;color:#765442;font-size:25rpx}.error{color:#b64a45;margin-top:22rpx;font-size:25rpx}
