.login-page{min-height:100vh;box-sizing:border-box;padding:180rpx 44rpx 80rpx;background:#f7f5f1;text-align:center}.brand-mark{width:112rpx;height:112rpx;margin:0 auto 24rpx;border-radius:34rpx;background:#fff;box-shadow:0 16rpx 45rpx rgba(75,55,40,.1);display:flex;align-items:center;justify-content:center}.brand-mark image{width:76rpx;height:76rpx}.brand-title{font-size:48rpx;font-weight:750;color:#29221d}.brand-copy{margin:14rpx 0 70rpx;color:#84776d;font-size:27rpx}.login-card{position:relative;text-align:left;background:#fff;border:1rpx solid #ebe5dd;border-radius:30rpx;padding:42rpx 34rpx 78rpx;box-shadow:0 24rpx 60rpx rgba(75,55,40,.08)}.mode-title{font-size:36rpx;font-weight:700}.mode-copy{color:#8b8178;font-size:25rpx;margin:12rpx 0 28rpx}.wechat-button,.account-button{height:96rpx;border-radius:20rpx;color:#fff;font-weight:650;display:flex;align-items:center;justify-content:center}.wechat-button{background:#07c160}.wechat-button image{width:44rpx;height:44rpx;margin-right:18rpx}.account-button{background:#765442;margin-top:28rpx}.switch{position:absolute;right:34rpx;bottom:28rpx;color:#765442;font-size:25rpx}.error{color:#b64a45;margin-top:22rpx;font-size:25rpx}
