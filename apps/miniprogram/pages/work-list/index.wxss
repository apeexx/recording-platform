.work-list-page{padding-top:calc(32rpx + env(safe-area-inset-top));padding-bottom:calc(40rpx + env(safe-area-inset-bottom))}.filters{white-space:nowrap;margin:28rpx 0}.filter{display:inline-flex;width:auto;margin:0 14rpx 0 0;padding:0 28rpx;border-radius:999rpx;background:#efe9df;color:#735947}.filter.active{background:#8a4a32;color:#fff}.work-row strong{font-size:34rpx}.tag.status-REWORK_PENDING{background:#fff0ed;color:#b4473b}.tag.status-SUBMITTED{background:#eef6ff;color:#3168a8}.tag.status-REVIEW_PENDING{background:#fff7e7;color:#9a6819}.tag.status-COMPLETED{background:#eaf7ef;color:#2d7a4c}.rework-reason{margin-top:20rpx;padding:18rpx;border-radius:14rpx;background:#fff4f0;color:#a83b35;line-height:1.6}.pagination{display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:18rpx;margin-top:30rpx}.page-button{width:auto;min-width:152rpx;height:72rpx;margin:0;padding:0 24rpx;border-radius:16rpx;background:#fff;color:#2563eb;font-size:26rpx;line-height:72rpx}.page-button[disabled]{background:#f1f5f9;color:#94a3b8}.page-summary{min-width:220rpx;text-align:center;color:#64748b;font-size:25rpx}
