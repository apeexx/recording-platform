<view class="page work-list-page"><view class="title">我的待办</view><view class="subtle">返修数据优先显示，点击后才会进入录制。</view><scroll-view class="filters" scroll-x><button wx:for="{{filters}}" wx:key="value" class="filter {{kind===item.value?'active':''}}" data-kind="{{item.value}}" bindtap="filter">{{item.label}}</button></scroll-view><view wx:if="{{error}}" class="error">{{error}}</view><view wx:if="{{loading}}" class="empty">正在加载…</view><view wx:elif="{{!items.length}}" class="empty">当前没有待办数据</view><view wx:for="{{items}}" wx:key="id" class="card work-row" data-id="{{item.id}}" bindtap="open"><view class="row"><view><strong>{{item.itemCode}}</strong><view class="subtle">{{item.taskCode}} · {{item.taskName}}</view></view><view class="tag {{item.status==='REWORK_PENDING'?'rework':''}}">{{item.status==='REWORK_PENDING'?'待返修':'待录制'}}</view></view><view wx:if="{{item.currentRejection}}" class="rework-reason"><text wx:for="{{item.currentRejection.reasons}}" wx:key="*this">{{item}} </text><text>{{item.currentRejection.note}}</text></view></view></view>
