.settings-page{padding-top:calc(28rpx + env(safe-area-inset-top));padding-bottom:80rpx}.avatar-card{box-sizing:border-box;width:100%;display:flex;align-items:center;gap:24rpx;margin:0;padding:34rpx 30rpx;text-align:left;line-height:1.4}.avatar-card::after{border:0}.avatar{width:116rpx;height:116rpx;flex:none;border-radius:58rpx;background:#eee7df}.avatar-content{flex:1;min-width:0}.avatar-title{font-size:34rpx;font-weight:700;margin-bottom:8rpx}.avatar-chevron{font-size:54rpx;line-height:1;color:#938a83}.restore-avatar{width:max-content;height:70rpx;line-height:70rpx;margin:4rpx 8rpx 24rpx auto;padding:0 18rpx;background:transparent;color:#746359;font-size:27rpx}.restore-avatar::after{border:0}.section{padding:42rpx 34rpx}.password-section{padding:42rpx 34rpx}.section-head,.label{display:flex;align-items:center}.section-head{gap:20rpx;margin-bottom:30rpx}.section-head image{width:56rpx;height:56rpx}.section-title{font-size:34rpx;font-weight:700}.field{margin-top:24rpx}.label{font-size:27rpx;color:#55483f}.label image{width:34rpx;height:34rpx;margin-right:10rpx}.input{height:88rpx;margin-top:14rpx;padding:0 28rpx;border-radius:18rpx}.input[disabled]{background:#f1efec;color:#938a83}.avatar-mask{position:fixed;z-index:10;inset:0;background:rgba(23,32,51,.5);display:flex;align-items:flex-end}.avatar-preview{box-sizing:border-box;width:100%;background:#fff;text-align:center;border-radius:32rpx;margin:0 32rpx 48rpx;padding:40rpx 32rpx}.avatar-sheet-title{font-size:32rpx;font-weight:700;margin-bottom:22rpx}.avatar-preview-image{width:220rpx;height:220rpx;border-radius:110rpx;margin:6rpx 0 20rpx;background:#eee7df}.preview-actions{display:flex;gap:18rpx;margin-top:30rpx}.preview-cancel,.preview-save{flex:1;height:92rpx;line-height:92rpx;margin:0;border-radius:18rpx;font-size:30rpx}.preview-cancel{background:#edf2ff;color:#2563eb}.preview-save{background:#2563eb;color:#fff}
