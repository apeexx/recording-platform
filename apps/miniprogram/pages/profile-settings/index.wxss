.settings-page{padding-top:calc(28rpx + env(safe-area-inset-top));padding-bottom:80rpx}.avatar-card{display:flex;align-items:center;gap:28rpx;margin-bottom:14rpx}.avatar{width:116rpx;height:116rpx;border-radius:58rpx;background:#eee7df}.avatar-title{font-size:34rpx;font-weight:700;margin-bottom:8rpx}.avatar-actions{display:flex;gap:18rpx;margin-bottom:30rpx}.small{flex:1;margin:0;background:#765442;color:#fff;border-radius:16rpx;font-size:26rpx}.small.ghost{background:#eee9e3;color:#654d40}.section-head,.label{display:flex;align-items:center}.section-head{gap:20rpx;margin-bottom:26rpx}.section-head image{width:56rpx;height:56rpx}.section-title{font-size:34rpx;font-weight:700}.field{margin-top:24rpx}.label{font-size:27rpx;color:#55483f}.label image{width:34rpx;height:34rpx;margin-right:10rpx}.input[disabled]{background:#f1efec;color:#938a83}
