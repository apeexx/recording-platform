.work-page{padding-bottom:calc(40rpx + env(safe-area-inset-bottom))}.work-title{font-size:34rpx;margin:0}.status-actions{gap:12rpx}.trash-button{display:grid;place-items:center;width:64rpx;height:64rpx;margin:0;padding:0;border-radius:50%;background:#fff0ed;color:#c2413b;font-size:30rpx}.reference-text{font-size:34rpx;line-height:1.7;margin-top:24rpx;white-space:pre-wrap}.rejection-box{margin-top:24rpx;padding:20rpx;border-radius:16rpx;background:#fff2ef;color:#a83b35;line-height:1.6}.recorder-card{min-height:340rpx;display:flex;flex-direction:column;align-items:center;justify-content:center}.mic-button{display:grid;place-items:center;width:164rpx;height:164rpx;padding:0;border-radius:50%;background:linear-gradient(145deg,#d96b4d,#b94b3d);color:#fff;font-size:70rpx;box-shadow:0 20rpx 48rpx rgba(185,75,61,.28)}.wave{height:120rpx;display:flex;align-items:center;gap:12rpx;margin-bottom:28rpx}.wave-bar{width:12rpx;min-height:8rpx;border-radius:999rpx;background:#d96b4d;transition:height .08s}.record-actions{display:flex;gap:36rpx}.control-button,.stop-button{display:flex;flex-direction:column;align-items:center;justify-content:center;width:136rpx;height:136rpx;border-radius:50%;font-size:44rpx}.control-button{background:#f3e8dc;color:#8a4a32}.stop-button{background:#fff0ed;color:#c2413b}.control-button text,.stop-button text{font-size:22rpx;margin-top:4rpx}.recording-result{width:100%}.recording-result>view{display:flex;justify-content:space-between}.recording-result text{color:#8a7668}.media{display:block;width:100%;margin-top:20rpx}
