<view class="page work-page">
  <view wx:if="{{loading}}" class="empty">正在加载作业…</view>
  <view wx:elif="{{loadError}}" class="empty"><view>{{loadError}}</view><button class="button retry-button" bindtap="load">重新加载</button></view>
  <block wx:else>
    <view class="card task-card">
      <view class="task-heading">
        <view class="task-identity"><view class="title work-title">数据 {{item.itemCode}}</view><view class="subtle">任务版本 v{{item.taskVersionNumber}}</view></view>
        <view class="status-actions"><view class="tag">{{statusText}}</view><button wx:if="{{canRelease}}" class="trash-button" loading="{{releasing}}" aria-label="释放任务" bindtap="release"><image src="../../assets/icons/iconfont/trash.svg" mode="aspectFit" /></button></view>
      </view>
      <view wx:if="{{item.currentRejection}}" class="rejection-box"><text>驳回原因：</text><text wx:for="{{item.currentRejection.reasons}}" wx:key="*this">{{item}} </text><text>{{item.currentRejection.note}}</text></view>
      <view wx:if="{{item.referenceText}}" class="reference-text">{{item.referenceText}}</view>
      <audio-player wx:if="{{referenceAudioPath}}" class="reference-player" src="{{referenceAudioPath}}" label="参考音频" duration-millis="0" bindplayrequest="audioPlayRequest" binderror="referenceAudioPlaybackError" />
      <video wx:if="{{referenceVideoPath}}" id="reference-video" class="media" src="{{referenceVideoPath}}" controls bindplay="videoPlay" binderror="videoPlaybackError" />
    </view>

    <view wx:if="{{editable}}" class="card recorder-card">
      <view class="recorder-stage">
        <view wx:if="{{recordState==='idle'||recordState==='error'}}" class="recorder-state idle-state">
          <button class="mic-button" aria-label="开始录音" bindtap="startRecord"><image src="../../assets/icons/iconfont/microphone.svg" mode="aspectFit" /></button>
          <view class="recorder-hint">点击开始录音</view>
        </view>

        <view wx:elif="{{recordState==='recording'||recordState==='paused'}}" class="recorder-state active-state">
          <view class="recording-status"><view class="status-dot {{recordState==='paused'?'paused':''}}"></view><text>{{recordState==='paused'?'已暂停':'录音中'}}</text></view>
          <view class="wave"><view wx:for="{{levelBars}}" wx:key="index" class="wave-bar" style="height:{{recordState==='paused'?8:item}}rpx" /></view>
          <view class="record-actions">
            <button wx:if="{{recordState==='recording'}}" class="record-control" bindtap="pauseRecord"><image src="../../assets/icons/iconfont/pause.svg" mode="aspectFit" /><text>暂停</text></button>
            <button wx:else class="record-control" bindtap="resumeRecord"><image src="../../assets/icons/iconfont/resume.svg" mode="aspectFit" /><text>继续</text></button>
            <button class="record-control stop-control" bindtap="stopRecord"><image src="../../assets/icons/iconfont/stop.svg" mode="aspectFit" /><text>结束</text></button>
          </view>
        </view>

        <view wx:elif="{{recordState==='stopping'}}" class="recorder-state processing-state"><view class="processing-ring"></view><view class="recorder-hint">正在生成音频…</view></view>

        <view wx:elif="{{audioPath&&recordState==='stopped'}}" class="recorder-state completed-state">
          <audio-player src="{{audioPath}}" label="录制音频" duration-millis="{{audioDuration}}" bindplayrequest="audioPlayRequest" binderror="audioPlaybackError" />
          <button class="rerecord-button" bindtap="startRecord">重新录制</button>
        </view>
      </view>
    </view>

    <view wx:if="{{readOnly}}" class="card readonly-result">
      <audio-player wx:if="{{audioPath}}" src="{{audioPath}}" label="已提交录音" duration-millis="{{audioDuration}}" bindplayrequest="audioPlayRequest" binderror="audioPlaybackError" />
      <view wx:else class="subtle">暂无可播放录音</view>
    </view>

    <view wx:if="{{version.resultType==='TEXT'&&editable}}" class="card"><view class="section-title">文本结果</view><textarea class="textarea" maxlength="-1" placeholder="请输入文本" value="{{text}}" bindinput="textInput" /></view>
    <view wx:if="{{version.resultType==='TEXT'&&readOnly}}" class="card"><view class="section-title">文本结果</view><view class="readonly-text">{{text||'暂无文本'}}</view></view>
    <view wx:if="{{editable}}" class="card submit-card">
      <view wx:if="{{showAutoClaimNext}}" class="auto-next-row"><view><view class="auto-next-title">提交后自动领取下一条</view><view class="subtle">提交成功后直接进入下一条作业</view></view><switch checked="{{autoClaimNextEnabled}}" color="#2563eb" bindchange="autoClaimNextChange" /></view>
      <button class="button submit-button" loading="{{submitting}}" disabled="{{submitting||recordState==='recording'||recordState==='paused'||recordState==='stopping'}}" bindtap="submit">{{submitLabel}}</button>
    </view>
  </block>
</view>
