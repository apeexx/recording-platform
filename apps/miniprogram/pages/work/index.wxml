<view class="page">
  <view wx:if="{{loading}}" class="empty">正在加载作业…</view>
  <block wx:else>
    <view wx:if="{{error}}" class="error">{{error}}</view>
    <view class="card">
      <view class="row"><view class="title work-title">数据 {{item.itemCode}}</view><view class="tag">{{statusText}}</view></view>
      <view class="subtle">任务版本 v{{item.taskVersionNumber}}</view>
      <view wx:if="{{item.referenceText}}" class="reference-text">{{item.referenceText}}</view>
      <audio wx:if="{{referenceAudioPath}}" class="media" src="{{referenceAudioPath}}" controls></audio>
      <video wx:if="{{referenceVideoPath}}" class="media" src="{{referenceVideoPath}}" controls></video>
    </view>
    <view class="card center">
      <view class="timer">{{durationText}}</view>
      <view class="subtle">{{recordStateText}}</view>
      <button wx:if="{{recordState==='idle'||recordState==='stopped'}}" class="button" bindtap="startRecord">{{audioPath?'重新录制':'开始录音'}}</button>
      <button wx:elif="{{recordState==='recording'}}" class="button secondary" bindtap="pauseRecord">暂停</button>
      <button wx:elif="{{recordState==='paused'}}" class="button secondary" bindtap="resumeRecord">继续</button>
      <button wx:if="{{recordState==='recording'||recordState==='paused'}}" class="button danger" bindtap="stopRecord">停止录音</button>
      <audio wx:if="{{audioPath&&recordState==='stopped'}}" class="media" src="{{audioPath}}" controls></audio>
    </view>
    <view wx:if="{{version.textInputEnabled}}" class="card">
      <view>文字结果（可单独提交）</view>
      <textarea class="textarea" maxlength="-1" placeholder="请输入普通话文本" value="{{text}}" bindinput="textInput"></textarea>
    </view>
    <view class="card">
      <view class="row"><text>提交后自动下一条</text><switch checked="{{autoNext}}" bindchange="autoNextChange" color="#2563eb" /></view>
      <button class="button" loading="{{submitting}}" disabled="{{submitting||recordState==='recording'||recordState==='paused'}}" bindtap="submit">提交作业</button>
      <button class="button danger" loading="{{releasing}}" bindtap="release">释放回数据池</button>
    </view>
  </block>
</view>
