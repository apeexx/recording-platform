<view class="page work-page">
  <view wx:if="{{loading}}" class="empty">正在加载作业…</view>
  <block wx:else>
    <view wx:if="{{error}}" class="error">{{error}}</view>
    <view class="card">
      <view class="row">
        <view><view class="title work-title">数据 {{item.itemCode}}</view><view class="subtle">任务版本 v{{item.taskVersionNumber}}</view></view>
        <view class="row status-actions"><view class="tag">{{statusText}}</view><button class="trash-button" loading="{{releasing}}" bindtap="release">🗑</button></view>
      </view>
      <view wx:if="{{item.currentRejection}}" class="rejection-box"><text>驳回原因：</text><text wx:for="{{item.currentRejection.reasons}}" wx:key="*this">{{item}} </text><text>{{item.currentRejection.note}}</text></view>
      <view wx:if="{{item.referenceText}}" class="reference-text">{{item.referenceText}}</view>
      <audio wx:if="{{referenceAudioPath}}" class="media" src="{{referenceAudioPath}}" controls/>
      <video wx:if="{{referenceVideoPath}}" class="media" src="{{referenceVideoPath}}" controls/>
    </view>
    <view class="card recorder-card">
      <button wx:if="{{recordState==='idle'||recordState==='error'}}" class="mic-button" bindtap="startRecord">🎙</button>
      <view wx:if="{{recordState==='recording'||recordState==='paused'}}" class="wave"><view wx:for="{{levelBars}}" wx:key="index" class="wave-bar" style="height:{{recordState==='paused'?8:item}}rpx"/></view>
      <view wx:if="{{recordState==='recording'}}" class="record-actions"><button class="control-button" bindtap="pauseRecord">Ⅱ<text>暂停</text></button><button class="stop-button" bindtap="stopRecord">■<text>结束</text></button></view>
      <view wx:if="{{recordState==='paused'}}" class="record-actions"><button class="control-button" bindtap="resumeRecord">🎙<text>继续</text></button><button class="stop-button" bindtap="stopRecord">■<text>结束</text></button></view>
      <view wx:if="{{recordState==='stopping'}}" class="subtle">正在生成音频…</view>
      <view wx:if="{{audioPath&&recordState==='stopped'}}" class="recording-result"><view><strong>录制音频</strong><text>{{audioDurationText}}</text></view><audio class="media" src="{{audioPath}}" controls/><button class="button secondary" bindtap="startRecord">重新录制</button></view>
    </view>
    <view wx:if="{{version.resultType==='TEXT'}}" class="card"><view>文本结果</view><textarea class="textarea" maxlength="-1" placeholder="请输入文本" value="{{text}}" bindinput="textInput"/></view>
    <view class="card"><button class="button" loading="{{submitting}}" disabled="{{submitting||recordState==='recording'||recordState==='paused'||recordState==='stopping'}}" bindtap="submit">提交作业</button></view>
  </block>
</view>
