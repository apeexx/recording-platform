:host{display:block;width:100%}.audio-player{box-sizing:border-box;width:100%;padding:26rpx 24rpx;border:1rpx solid #e2e8f0;border-radius:20rpx;background:#f8fafc}.audio-header{display:flex;align-items:center;justify-content:space-between;gap:20rpx}.audio-label{font-size:28rpx;font-weight:600;color:#334155}.audio-time{flex:none;font-variant-numeric:tabular-nums;font-size:26rpx;color:#64748b}.audio-controls{display:flex;align-items:center;gap:18rpx;margin-top:22rpx}.play-button{display:grid;place-items:center;flex:none;width:76rpx;height:76rpx;margin:0;padding:0;border-radius:50%;background:#eef4ff}.play-button::after{border:none}.play-icon{width:28rpx;height:28rpx}.audio-slider{flex:1;margin:0;padding:0}
