page{background:#f4f7fb;color:#172033;font-size:30rpx}.page{padding:32rpx}.card{background:#fff;border:1rpx solid #e2e8f0;border-radius:24rpx;padding:30rpx;margin-bottom:24rpx;box-shadow:0 8rpx 30rpx rgba(15,23,42,.05)}.title{font-size:42rpx;font-weight:700;margin-bottom:12rpx}.subtle{color:#64748b;font-size:26rpx}.button{background:#2563eb;color:#fff;border-radius:18rpx;margin-top:22rpx}.button.secondary{background:#e8eefb;color:#1d4ed8}.button.danger{background:#fff1f2;color:#be123c;border:1rpx solid #fecdd3}.button[disabled]{opacity:.45}.input,.textarea{box-sizing:border-box;width:100%;border:1rpx solid #cbd5e1;border-radius:16rpx;padding:22rpx;margin-top:18rpx;background:#fff}.textarea{min-height:180rpx}.row{display:flex;align-items:center;justify-content:space-between;gap:20rpx}.tag{font-size:24rpx;padding:8rpx 16rpx;border-radius:999rpx;background:#eef2ff;color:#3730a3}.error{color:#b91c1c;margin:18rpx 0}.empty{text-align:center;color:#64748b;padding:90rpx 24rpx}.media{width:100%;margin-top:20rpx}.metric{font-size:40rpx;font-weight:700}.grid{display:grid;grid-template-columns:1fr 1fr;gap:18rpx}.center{text-align:center}
